# Official bluesky-social/pds environment config.
# Copy to pds.env (gitignored) and fill in real values before starting.
# Reference: https://github.com/bluesky-social/pds

# Public hostname the PDS is reachable at. Must resolve via DNS to this Pi
# and have valid TLS in front of it (Caddy/nginx reverse proxy, or run the
# PDS's own built-in Caddy — see the official install script for that path).
PDS_HOSTNAME=pds.yourdomain.example

# Where the PDS stores its data inside the container. Matches the volume
# mount target in docker-compose.yml — do not change without updating both.
PDS_DATA_DIRECTORY=/pds
PDS_BLOBSTORE_DISK_LOCATION=/pds/blocks

# Secrets — generate with: openssl rand --hex 16
PDS_JWT_SECRET=REPLACE_ME
PDS_ADMIN_PASSWORD=REPLACE_ME

# PLC rotation key — the private key that lets this PDS update its accounts'
# did:plc documents (e.g. on handle or service-endpoint changes). Generate
# with the PDS's own keygen: `docker run --rm ghcr.io/bluesky-social/pds:latest node dist/scripts/gen-jwks.js`
# or follow the official install script, which generates this automatically.
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=REPLACE_ME

# did:plc directory this PDS registers identities against. Using the public
# Bluesky-run directory (plc.directory) is the pragmatic default — it's the
# resolution service, not a trust or hosting dependency. Self-hosting a PLC
# directory too is possible but out of scope for now.
PDS_DID_PLC_URL=https://plc.directory

# Leave unset / empty to opt this PDS out of being crawled by the public
# Bluesky relay — domain agent records aren't meant for the public firehose.
PDS_CRAWLERS=

# Invite codes are required by default; not needed for a single-node setup.
PDS_INVITE_REQUIRED=false
